# Gateway2Models Environment Configuration
# Copy this file to .env and customize

# ── Server ────────────────────────────────────────
G2M_PORT=5555
G2M_HOST=127.0.0.1
G2M_MAX_CONCURRENCY=5
G2M_TIMEOUT_MS=300000

# ── Ollama (Local Models) ─────────────────────────
# Ollama must be running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── CLI Paths (auto-detected, override if needed) ─
# CLAUDE_CLI_PATH=
# AGENCY_CLI_PATH=
# COPILOT_CLI_PATH=
