# Gateway2Models Environment Configuration
# Copy this file to .env and customize

# ── Server ────────────────────────────────────────
G2M_PORT=5555
G2M_HOST=127.0.0.1
G2M_MAX_CONCURRENCY=5
G2M_TIMEOUT_MS=300000

# ── LAN Gateway (access from other devices) ──────
# Set to "true" to bind to 0.0.0.0 (all interfaces)
# Or use --lan flag: npm run start:lan
G2M_LAN=false

# ── Ollama (Local Models) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Generation (Image/Video) ─────────────────────
# Stability AI (free tier): https://platform.stability.ai/
# STABILITY_API_KEY=
# OpenAI (DALL-E): https://platform.openai.com/
# OPENAI_API_KEY=
# Replicate (video gen): https://replicate.com/
# REPLICATE_API_TOKEN=
# Local ComfyUI/Automatic1111:
# COMFYUI_BASE_URL=http://localhost:7860

# ── CLI Paths (auto-detected, override if needed) ─
# CLAUDE_CLI_PATH=
# AGENCY_CLI_PATH=
# COPILOT_CLI_PATH=
