{
  "name": "gateway2models",
  "version": "4.0.0",
  "description": "The model gateway for AI agents — multi-modal, multi-backend, persistent memory",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "gateway2models": "dist/server.js",
    "g2m": "dist/server.js",
    "g2m-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:lan": "G2M_LAN=true node dist/server.js",
    "mcp": "node dist/mcp-server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
